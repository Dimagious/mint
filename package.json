{
  "name": "social-posts-helper",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "description": "Self-hosted Instagram text-over-image editor",
  "scripts": {
    "dev": "pnpm --filter @social-posts-helper/web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @social-posts-helper/web test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,md}\"",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@10.29.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "canvas",
      "esbuild",
      "@playwright/browser-chromium"
    ]
  }
}
